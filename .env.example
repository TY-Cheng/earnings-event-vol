UV_PROJECT_ENVIRONMENT="${HOME}/.venvs/earnings-event-vol"

# This is a uv non-package project. The justfile runs the CLI with PYTHONPATH=src
# instead of relying on an installed console script.

PROJECT_NAME="earnings-event-vol"
LOG_LEVEL="INFO"

DATA_DIR="data"
BRONZE_DATA_DIR="data/bronze"
SILVER_DATA_DIR="data/silver"
GOLD_DATA_DIR="data/gold"
REPORTS_DIR="reports"
ARTIFACTS_DIR="artifacts"

# Credentials are file-only. Put secrets in local files outside the repo, then
# point *_FILE variables at those files. Direct secret values are ignored.
MASSIVE_API_KEY_FILE=""
MASSIVE_FLAT_FILE_KEY_FILE=""
MASSIVE_BASE_URL="https://api.massive.com"
MASSIVE_FLAT_FILE_ENDPOINT_URL="https://files.massive.com"
MASSIVE_FLAT_FILE_BUCKET="flatfiles"
MASSIVE_OPTIONS_FLAT_FILE_DATASET="day_aggs_v1"
MASSIVE_OPTIONS_QUOTES_FLAT_FILE_DATASET="quotes_v1"
MASSIVE_OPTIONS_FLAT_FILE_TEMPLATE="s3://flatfiles/us_options_opra/day_aggs_v1/{year}/{month}/{date}.csv.gz"
MASSIVE_OPTION_FLAT_FILE_KEY_TEMPLATE="us_options_opra/{dataset}/{year}/{month}/{date}.csv.gz"
MASSIVE_OPTION_QUOTES_FLAT_FILE_KEY_TEMPLATE="us_options_opra/{dataset}/{year}/{month}/{date}.csv.gz"
MASSIVE_UNDERLYING_FLAT_FILE_TEMPLATE="s3://flatfiles/us_stocks_sip/day_aggs_v1/{year}/{month}/{date}.csv.gz"
MASSIVE_UNDERLYING_FLAT_FILE_KEY_TEMPLATE="us_stocks_sip/{dataset}/{year}/{month}/{date}.csv.gz"
MASSIVE_REQUEST_TIMEOUT_SECONDS="30"
MASSIVE_MAX_RETRIES="3"
MASSIVE_RETRY_BACKOFF_SECONDS="2"
# Leave blank for no local client-side throttle. Set an integer only if you want a stricter cap.
MASSIVE_REQUESTS_PER_MINUTE=""
MASSIVE_8K_TEXT_PATH="/stocks/filings/8-K/vX/text"

SEC_COMPANY_TICKERS_URL="https://www.sec.gov/files/company_tickers.json"
SEC_SUBMISSIONS_URL_TEMPLATE="https://data.sec.gov/submissions/CIK{cik:010d}.json"
SEC_USER_AGENT="earnings-event-vol research contact no-reply@example.com"
